// Codevertex Website — Prisma Schema
// Prisma 7 — connection URL is in prisma.config.ts, not here

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("contact_submissions")
}

model Lead {
  id            BigInt   @id @default(autoincrement())
  name          String?
  email         String?
  phone         String?
  topic         String?
  preferredTime String?  @map("preferred_time")
  source        String   @default("chatbot")
  notes         String?
  status        String   @default("new")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("leads")
}

model StudentUser {
  id        String   @id  // DGT-XXXXXXXX unique student ID
  email     String   @unique
  fullName  String   @map("full_name")
  phone     String
  dob       DateTime? @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enrollments Enrollment[]

  @@index([email])
  @@map("student_users")
}

// ---------------------------------------------------------------------------
// Discount rules — admin-configurable promo discounts for course enrollments
// ---------------------------------------------------------------------------
model DiscountRule {
  id            BigInt    @id @default(autoincrement())
  name          String                        // e.g. "Early Bird — May 2026"
  code          String    @unique             // e.g. "EARLY5" or "FIRST10"
  description   String?
  discountPct   Int?      @map("discount_pct")    // percentage (1-100), mutually exclusive with discountAmount
  discountAmount Int?     @map("discount_amount")  // fixed KES amount off
  courseId      String?   @map("course_id")   // null = applies to all courses
  maxUses       Int?      @map("max_uses")    // null = unlimited
  usedCount     Int       @default(0) @map("used_count")
  validFrom     DateTime? @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  enrollments   Enrollment[]

  @@index([code])
  @@index([active])
  @@map("discount_rules")
}

model Enrollment {
  id              BigInt    @id @default(autoincrement())
  courseId        String    @map("course_id")
  courseName      String    @map("course_name")
  category        String
  fullName        String    @map("full_name")
  email           String
  phone           String
  dob             DateTime? @db.Date
  experience      String?
  howHeard        String?   @map("how_heard")
  amount          Int                        // first payment amount (installment 1 or full)
  totalAmount     Int?      @map("total_amount")  // full course price
  currency        String    @default("KES")
  paymentRef      String?   @map("payment_ref")
  paymentStatus   String    @default("pending") @map("payment_status")
  paymentPlan     String?   @map("payment_plan")  // 'upfront' | '2-installments' | '3-installments'
  installmentNo   Int?      @map("installment_no")
  cohortId        BigInt?   @map("cohort_id")
  studentUserId   String?   @map("student_user_id")
  notifiedAt      DateTime? @map("notified_at")
  // Discount fields — set at enrollment time from applicable DiscountRule
  discountRuleId  BigInt?   @map("discount_rule_id")
  discountCode    String?   @map("discount_code")
  discountPct     Int?      @map("discount_pct")    // percentage applied (0-100)
  discountAmount  Int?      @map("discount_amount")  // absolute KES discount applied
  createdAt       DateTime  @default(now()) @map("created_at")

  cohort        Cohort?       @relation(fields: [cohortId], references: [id])
  studentUser   StudentUser?  @relation(fields: [studentUserId], references: [id])
  discountRule  DiscountRule? @relation(fields: [discountRuleId], references: [id])
  installments  InstallmentSchedule[]

  @@index([email])
  @@index([paymentStatus])
  @@index([studentUserId])
  @@index([discountRuleId])
  @@map("enrollments")
}

model InstallmentSchedule {
  id            BigInt    @id @default(autoincrement())
  enrollmentId  BigInt    @map("enrollment_id")
  installmentNo Int       @map("installment_no")  // 1, 2, 3
  amount        Int
  currency      String    @default("KES")
  dueDate       DateTime  @map("due_date") @db.Date
  paidAt        DateTime? @map("paid_at")
  paymentRef    String?   @map("payment_ref")
  status        String    @default("pending")  // pending | paid | overdue | reminded
  reminderSentAt DateTime? @map("reminder_sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([enrollmentId])
  @@index([dueDate])
  @@index([status])
  @@map("installment_schedules")
}

model Cohort {
  id                BigInt       @id @default(autoincrement())
  courseId          String       @map("course_id")
  name              String
  startDate         DateTime     @map("start_date") @db.Date
  endDate           DateTime?    @map("end_date") @db.Date
  registrationFrom       DateTime?    @map("registration_from")        // when enrollment/registration opens
  registrationUntil      DateTime?    @map("registration_until")       // registration deadline (discount valid-until auto-filled from this)
  registrationExtDays    Int          @default(0) @map("registration_ext_days")  // admin-granted extension in days added on top of registrationUntil
  maxSlots          Int          @default(20) @map("max_slots")
  status            String       @default("open")
  createdAt         DateTime     @default(now()) @map("created_at")

  enrollments Enrollment[]

  @@map("cohorts")
}

// ---------------------------------------------------------------------------
// Courses — DB-driven course catalog (mirrors courses.ts config)
// ---------------------------------------------------------------------------
model Course {
  id              String   @id
  categoryId      String   @map("category_id")
  name            String
  shortName       String?  @map("short_name")
  slug            String   @unique
  duration        String
  mode            String
  price           Int
  currency        String   @default("KES")
  description     String
  longDescription String?  @map("long_description") @db.Text
  level           String   @default("beginner")
  audience        String?
  stack           String?
  coverImage      String?  @map("cover_image")
  outcomes        String[]
  prerequisites   String[] @default([])
  careerPaths     String[] @default([]) @map("career_paths")
  includes        String[] @default([])
  featured            Boolean  @default(false)
  isActive            Boolean  @default(true) @map("is_active")
  installmentsEnabled Boolean  @default(true) @map("installments_enabled")
  installmentPlans    Json?    @default("[]") @map("installment_plans")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([featured])
  @@index([isActive])
  @@map("courses")
}

// ---------------------------------------------------------------------------
// Blog posts — CMS for the /blog section
// ---------------------------------------------------------------------------
model BlogPost {
  id          BigInt    @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  author      String
  coverImage  String?   @map("cover_image")
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([published])
  @@index([publishedAt(sort: Desc)])
  @@index([slug])
  @@map("blog_posts")
}

// ---------------------------------------------------------------------------
// Site users — SSO-synced users who log in via accounts.codevertexitsolutions.com
// ---------------------------------------------------------------------------
model SiteUser {
  id          String    @id
  email       String    @unique
  fullName    String?   @map("full_name")
  avatarUrl   String?   @map("avatar_url")
  role        String    @default("member")  // 'member' | 'admin'
  tenantId    String?   @map("tenant_id")
  tenantSlug  String?   @map("tenant_slug")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([tenantId])
  @@index([role])
  @@map("site_users")
}
