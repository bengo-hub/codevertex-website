// Codevertex Website — Prisma Schema
// Prisma 7 — connection URL is in prisma.config.ts, not here

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("contact_submissions")
}

model Lead {
  id            BigInt   @id @default(autoincrement())
  name          String?
  email         String?
  phone         String?
  topic         String?
  preferredTime String?  @map("preferred_time")
  source        String   @default("chatbot")
  notes         String?
  status        String   @default("new")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("leads")
}

model Enrollment {
  id            BigInt    @id @default(autoincrement())
  courseId      String    @map("course_id")
  courseName    String    @map("course_name")
  category      String
  fullName      String    @map("full_name")
  email         String
  phone         String
  dob           DateTime? @db.Date
  experience    String?
  howHeard      String?   @map("how_heard")
  amount        Int
  currency      String    @default("KES")
  paymentRef    String?   @map("payment_ref")
  paymentStatus String    @default("pending") @map("payment_status")
  paymentPlan   String?   @map("payment_plan")
  installmentNo Int?      @map("installment_no")
  cohortId      BigInt?   @map("cohort_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  cohort Cohort? @relation(fields: [cohortId], references: [id])

  @@index([email])
  @@index([paymentStatus])
  @@map("enrollments")
}

model Cohort {
  id          BigInt       @id @default(autoincrement())
  courseId    String       @map("course_id")
  name        String
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  maxSlots    Int          @default(20) @map("max_slots")
  status      String       @default("open")
  createdAt   DateTime     @default(now()) @map("created_at")

  enrollments Enrollment[]

  @@map("cohorts")
}

// ---------------------------------------------------------------------------
// Courses — DB-driven course catalog (mirrors courses.ts config)
// ---------------------------------------------------------------------------
model Course {
  id              String   @id
  categoryId      String   @map("category_id")
  name            String
  shortName       String?  @map("short_name")
  slug            String   @unique
  duration        String
  mode            String
  price           Int
  currency        String   @default("KES")
  description     String
  longDescription String?  @map("long_description") @db.Text
  level           String   @default("beginner")
  audience        String?
  stack           String?
  coverImage      String?  @map("cover_image")
  outcomes        String[]
  prerequisites   String[] @default([])
  careerPaths     String[] @default([]) @map("career_paths")
  includes        String[] @default([])
  featured        Boolean  @default(false)
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([featured])
  @@index([isActive])
  @@map("courses")
}

// ---------------------------------------------------------------------------
// Blog posts — CMS for the /blog section
// ---------------------------------------------------------------------------
model BlogPost {
  id          BigInt    @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  author      String
  coverImage  String?   @map("cover_image")
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([published])
  @@index([publishedAt(sort: Desc)])
  @@index([slug])
  @@map("blog_posts")
}

// ---------------------------------------------------------------------------
// Site users — SSO-synced users who log in via accounts.codevertexitsolutions.com
// ---------------------------------------------------------------------------
model SiteUser {
  id          String    @id
  email       String    @unique
  fullName    String?   @map("full_name")
  avatarUrl   String?   @map("avatar_url")
  role        String    @default("member")
  tenantId    String?   @map("tenant_id")
  tenantSlug  String?   @map("tenant_slug")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([tenantId])
  @@map("site_users")
}
